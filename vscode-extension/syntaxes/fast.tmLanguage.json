{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Fast",
  "scopeName": "source.fast",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "builtins": {
      "patterns": [
        {
          "name": "support.function.fast",
          "match": "\\bprint\\b"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.fast",
          "match": "//.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "storage.modifier.fast",
          "match": "\\b(?:val|var)\\b"
        },
        {
          "name": "keyword.control.fast",
          "match": "\\b(?:do|for|function|of|return|while)\\b"
        },
        {
          "name": "constant.language.null.fast",
          "match": "\\bnull\\b"
        },
        {
          "name": "support.type.fast",
          "match": "\\b(?:array|boolean|double|float|int|string|void)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.double.fast",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.fast",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.fast",
          "match": "(?:==|!=|>=|<=|>|<)"
        },
        {
          "name": "keyword.operator.assignment.fast",
          "match": "(?:&&=|\\|\\|=|\\?\\?=|\\+=|-=|\\*=|/=|%=|=)"
        },
        {
          "name": "keyword.operator.logical.fast",
          "match": "(?:&&|\\|\\||\\?\\?)"
        },
        {
          "name": "keyword.operator.ternary.fast",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.arithmetic.fast",
          "match": "[+\\-*/%]"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.fast",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.fast",
          "match": ","
        },
        {
          "name": "punctuation.separator.type-annotation.fast",
          "match": ":"
        },
        {
          "name": "punctuation.section.braces.fast",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.brackets.fast",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.section.parens.fast",
          "match": "[()]"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.fast",
          "begin": "\"",
          "end": "\""
        },
        {
          "name": "string.quoted.backtick.fast",
          "begin": "`",
          "end": "`"
        }
      ]
    }
  }
}
