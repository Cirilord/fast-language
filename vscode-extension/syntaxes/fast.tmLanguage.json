{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Fast",
  "scopeName": "source.fast",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#generics"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#identifiers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "builtins": {
      "patterns": [
        {
          "name": "support.function.ts",
          "match": "\\bprint\\b"
        },
        {
          "name": "support.function.ts",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*(?:<[^>]+>)?\\s*\\()"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ts",
          "match": "//.*$"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(function)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.type.function.ts"
            },
            "2": {
              "name": "entity.name.function.ts"
            }
          }
        },
        {
          "match": "\\b(class)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.type.class.ts"
            },
            "2": {
              "name": "entity.name.type.class.ts"
            }
          }
        },
        {
          "match": "\\b(extends|implements)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.type.class.ts"
            },
            "2": {
              "name": "entity.name.type.class.ts"
            }
          }
        },
        {
          "match": "(:)\\s*([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "punctuation.separator.type-annotation.ts"
            },
            "2": {
              "name": "entity.name.type.class.ts"
            }
          }
        },
        {
          "match": "\\b(new)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.type.class.ts"
            },
            "2": {
              "name": "entity.name.type.class.ts"
            }
          }
        },
        {
          "name": "entity.name.type.class.ts",
          "match": "\\b[A-Z][A-Za-z0-9_]*(?=\\s*\\.)"
        },
        {
          "match": "\\b(var)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.type.ts"
            },
            "2": {
              "name": "variable.other.readwrite.ts"
            }
          }
        },
        {
          "match": "\\b(val)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.type.ts"
            },
            "2": {
              "name": "variable.other.readwrite.ts"
            }
          }
        }
      ]
    },
    "generics": {
      "patterns": [
        {
          "name": "entity.name.type.type-parameter.ts",
          "match": "(?<=<)\\s*[A-Za-z_][A-Za-z0-9_]*(?=\\s*(?:,|>|=))"
        },
        {
          "name": "entity.name.type.type-parameter.ts",
          "match": "(?<=,)\\s*[A-Za-z_][A-Za-z0-9_]*(?=\\s*(?:,|>|=))"
        },
        {
          "name": "entity.name.type.type-parameter.ts",
          "match": "\\b[A-Z]\\b"
        },
        {
          "name": "punctuation.definition.typeparameters.begin.ts",
          "match": "<"
        },
        {
          "name": "punctuation.definition.typeparameters.end.ts",
          "match": ">"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.readwrite.ts",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "storage.type.ts",
          "match": "\\bvar\\b"
        },
        {
          "name": "storage.type.ts",
          "match": "\\bval\\b"
        },
        {
          "name": "keyword.control.loop.ts",
          "match": "\\b(?:do|for|while)\\b"
        },
        {
          "name": "keyword.operator.expression.of.ts",
          "match": "\\bof\\b"
        },
        {
          "name": "storage.type.function.ts",
          "match": "\\bfunction\\b"
        },
        {
          "name": "keyword.control.flow.ts",
          "match": "\\breturn\\b"
        },
        {
          "name": "keyword.control.ts",
          "match": "\\b(?:export|from|import|new)\\b"
        },
        {
          "name": "storage.type.class.ts",
          "match": "\\b(?:extends|implements)\\b"
        },
        {
          "name": "storage.modifier.ts",
          "match": "\\b(?:abstract|constructor|override|private|protected|public|static|virtual)\\b"
        },
        {
          "name": "storage.type.class.ts",
          "match": "\\bclass\\b"
        },
        {
          "name": "variable.language.ts",
          "match": "\\b(?:super|this)\\b"
        },
        {
          "name": "constant.language.null.ts",
          "match": "\\bnull\\b"
        },
        {
          "name": "support.type.primitive.ts",
          "match": "\\b(?:array|boolean|double|float|int|string|void)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.decimal.ts",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.decimal.ts",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.ts",
          "match": "(?:==|!=|>=|<=|>|<)"
        },
        {
          "name": "keyword.operator.assignment.ts",
          "match": "(?:&&=|\\|\\|=|\\?\\?=|\\+=|-=|\\*=|/=|%=|=)"
        },
        {
          "name": "keyword.operator.logical.ts",
          "match": "(?:&&|\\|\\||\\?\\?)"
        },
        {
          "name": "keyword.operator.ternary.ts",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.arithmetic.ts",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.accessor.ts",
          "match": "\\."
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.ts",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.ts",
          "match": ","
        },
        {
          "name": "punctuation.separator.type-annotation.ts",
          "match": ":"
        },
        {
          "name": "punctuation.section.braces.ts",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.brackets.ts",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.section.parens.ts",
          "match": "[()]"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ts",
          "begin": "\"",
          "end": "\""
        },
        {
          "name": "string.template.ts",
          "begin": "`",
          "end": "`"
        }
      ]
    }
  }
}
